default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :testflight do
    setup_ci if is_ci
    
    # Build the app
    build_app(
      project: "Tellsla.xcodeproj",
      scheme: "Tellsla",
      configuration: "Release",
      derived_data_path: "build",
      destination: "generic/platform=iOS",
      archive_path: "build/Tellsla.xcarchive",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        signingStyle: "automatic",
        teamID: "894G4S5K4R",
        stripSwiftSymbols: true,
        thinning: "<none>"
      },
      skip_package_ipa: false,
      skip_package_pkg: true,
      output_directory: "build/ipa",
      output_name: "Tellsla.ipa",
      skip_app_version_update: true,
      skip_package_dependencies_resolution: false
    )
    
    # Upload to TestFlight
    upload_to_testflight(
      ipa: "build/ipa/Tellsla.ipa",
      skip_submission: true,
      skip_waiting_for_build_processing: true,
      api_key_path: "fastlane/app_store_connect_api_key.json"
    )
    
    puts("✅ Build uploaded to TestFlight successfully!")
  end

  desc "Match provisioning profiles (requires match credentials)"
  lane :match_profiles do
    # This would sync profiles from git repo - optional for now
    # match(type: "appstore", readonly: true)
  end
end
