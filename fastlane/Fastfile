default_platform(:ios)

platform :ios do
  desc "Build and upload Tellsla to TestFlight"
  lane :testflight do
    # Setup for CI
    setup_ci if is_ci
    
    # Sync provisioning profiles and certificates using match
    # match(
    #   type: "appstore",
    #   app_identifier: ["app.rork.tellsla", "app.rork.tellsla.TellslaWatch", "app.rork.tellsla.TellslaWidget"],
    #   readonly: is_ci,
    #   git_basic_authorization: ENV["MATCH_GIT_AUTH"]
    # )
    
    # Build and upload
    build_app(
      project: "Tellsla.xcodeproj",
      scheme: "Tellsla",
      configuration: "Release",
      destination: "generic/platform=iOS",
      derived_data_path: "build",
      archive_path: "build/Tellsla.xcarchive",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        signingStyle: "automatic",
        teamID: "894G4S5K4R",
        stripSwiftSymbols: true,
        thinning: "<none>"
      },
      skip_package_ipa: false,
      output_directory: "build/ipa",
      output_name: "Tellsla.ipa",
      skip_app_version_update: true
    )
    
    # Upload to TestFlight
    upload_to_testflight(
      ipa: "build/ipa/Tellsla.ipa",
      skip_submission: true,
      skip_waiting_for_build_processing: true,
      api_key_path: "fastlane/app_store_connect_key.json"
    )
    
    puts("✅ Successfully uploaded to TestFlight!")
  end
end
